<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#000000"
                android:centerColor="#120303"
                android:endColor="#2A0606" />
        </shape>
    </item>
    <item android:left="-120dp" android:top="-120dp" android:right="140dp" android:bottom="420dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="280dp"
                android:centerColor="#80D32F2F"
                android:endColor="#00D32F2F" />
        </shape>
    </item>
</layer-list>
