<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Video display area - full screen -->
    <FrameLayout
        android:id="@+id/video_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/image_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true" />

        <net.sourceforge.opencamera.FinishOverlayView
            android:id="@+id/overlay_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- Frame info overlay at top -->
    <LinearLayout
        android:id="@+id/info_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#60000000">

        <TextView
            android:id="@+id/time_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00.000"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/frame_info_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Frame: 1 / 100  |  30 fps"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/null_time_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="From null: +00:00.000 (+0 frames)"
            android:textColor="#FF5555"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Controls container at bottom - semi-transparent, with extra margin for gesture bar -->
    <LinearLayout
        android:id="@+id/controls_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="64dp"
        android:orientation="vertical"
        android:background="#60000000"
        android:padding="8dp">

        <!-- Timeline seekbar -->
        <SeekBar
            android:id="@+id/frame_seekbar"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginBottom="2dp" />

        <!-- All controls in one row for landscape -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Prev frame -->
            <ImageButton
                android:id="@+id/btn_prev_frame"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_skip_previous_white_48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Previous frame"
                android:scaleType="centerInside"
                android:alpha="0.9" />

            <!-- Play -->
            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_play_arrow_white_48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Play/Pause"
                android:scaleType="centerInside"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:alpha="0.9" />

            <!-- Next frame -->
            <ImageButton
                android:id="@+id/btn_next_frame"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_skip_next_white_48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Next frame"
                android:scaleType="centerInside"
                android:alpha="0.9" />

            <!-- Separator -->
            <View
                android:layout_width="1dp"
                android:layout_height="30dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="#40FFFFFF" />

            <!-- Toggle line -->
            <ImageButton
                android:id="@+id/btn_toggle_line"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_vertical_line_white_48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Toggle vertical line"
                android:scaleType="centerInside"
                android:alpha="0.9" />

            <!-- Set null -->
            <ImageButton
                android:id="@+id/btn_set_null"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_flag_white_48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Set null point"
                android:scaleType="centerInside"
                android:layout_marginStart="12dp"
                android:alpha="0.9" />

            <!-- Clear null -->
            <ImageButton
                android:id="@+id/btn_clear_null"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_clear_white_48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Clear null point"
                android:scaleType="centerInside"
                android:layout_marginStart="12dp"
                android:alpha="0.9" />

            <!-- Save frame -->
            <ImageButton
                android:id="@+id/btn_save_frame"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_save_white_48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Save frame"
                android:scaleType="centerInside"
                android:layout_marginStart="12dp"
                android:alpha="0.9" />

            <!-- Open video from gallery -->
            <ImageButton
                android:id="@+id/btn_open_video"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_folder_video_white_48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Open video"
                android:scaleType="centerInside"
                android:layout_marginStart="12dp"
                android:alpha="0.9" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
