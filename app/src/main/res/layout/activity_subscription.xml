<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tv_subscription_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subscription_screen_title"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="24sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_subscription_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subscription_offer_launch"
            android:textColor="#FFE0B2"
            android:gravity="center"
            android:textSize="15sp"
            android:layout_marginBottom="24dp" />

        <!-- Feature list -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#33FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subscription_features_title"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subscription_feature_1"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subscription_feature_2"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subscription_feature_3"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subscription_feature_4"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subscription_feature_5"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_buy_monthly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subscription_buy_monthly"
            android:layout_marginBottom="12dp"
            android:background="@drawable/launcher_button_primary"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn_buy_yearly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subscription_buy_yearly"
            android:layout_marginBottom="12dp"
            android:background="@drawable/launcher_button_primary"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn_buy_lifetime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subscription_buy_lifetime"
            android:layout_marginBottom="12dp"
            android:background="@drawable/launcher_button_secondary"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn_restore_purchases"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subscription_restore"
            android:layout_marginBottom="16dp"
            android:background="@drawable/launcher_button_secondary"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tv_billing_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subscription_status_loading"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textSize="14sp" />

    </LinearLayout>

</ScrollView>
