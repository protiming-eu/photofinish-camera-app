<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_camera"
            android:tint="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="32dp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_camera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/launcher_camera_button"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/launcher_button_primary"
            android:drawableLeft="@drawable/ic_camera"
            android:drawablePadding="12dp"
            android:gravity="center"
            android:maxWidth="450dp" />

        <Button
            android:id="@+id/btn_viewer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/launcher_viewer_button"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:padding="20dp"
            android:background="@drawable/launcher_button_secondary"
            android:drawableLeft="@drawable/ic_video_player"
            android:drawablePadding="12dp"
            android:gravity="center"
            android:maxWidth="450dp" />

        <TextView
            android:id="@+id/tv_subscription_offer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:maxWidth="450dp"
            android:gravity="center"
            android:textColor="#FFF3E0"
            android:textSize="14sp"
            android:text="@string/subscription_offer_launch" />

        <Button
            android:id="@+id/btn_subscription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:maxWidth="450dp"
            android:text="@string/launcher_subscription_button"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:padding="16dp"
            android:background="@drawable/launcher_button_primary"
            android:visibility="gone" />

        <!-- AdMob banner – shown only when user has no subscription -->
        <com.google.android.gms.ads.AdView
            xmlns:ads="http://schemas.android.com/apk/res-auto"
            android:id="@+id/ad_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            ads:adSize="BANNER"
            ads:adUnitId="@string/admob_banner_ad_unit_id" />

    </LinearLayout>

</ScrollView>
