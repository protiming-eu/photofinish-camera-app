<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_camera"
            android:tint="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Photo Finish Camera"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="32dp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_camera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=" Camera"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/launcher_button_primary"
            android:drawableLeft="@drawable/ic_camera"
            android:drawablePadding="12dp"
            android:gravity="center"
            android:maxWidth="450dp" />

        <Button
            android:id="@+id/btn_viewer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Frame-by-frame video player"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:padding="20dp"
            android:background="@drawable/launcher_button_secondary"
            android:drawableLeft="@drawable/ic_video_player"
            android:drawablePadding="12dp"
            android:gravity="center"
            android:maxWidth="450dp" />

    </LinearLayout>

</ScrollView>
