<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="20dp">

        <!-- Left side: Icon and title -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_camera"
                android:tint="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_title_land"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center" />

        </LinearLayout>

        <!-- Right side: Buttons -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="16dp">

            <Button
                android:id="@+id/btn_camera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/launcher_camera_button"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:padding="18dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/launcher_button_primary"
                android:drawableLeft="@drawable/ic_camera"
                android:drawablePadding="12dp"
                android:gravity="center"
                android:maxWidth="400dp" />

            <Button
                android:id="@+id/btn_viewer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/launcher_viewer_button"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:padding="18dp"
                android:background="@drawable/launcher_button_secondary"
                android:drawableLeft="@drawable/ic_video_player"
                android:drawablePadding="12dp"
                android:gravity="center"
                android:maxWidth="400dp" />

            <TextView
                android:id="@+id/tv_subscription_offer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="#FFF3E0"
                android:textSize="13sp"
                android:text="@string/subscription_offer_launch" />

            <Button
                android:id="@+id/btn_subscription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/launcher_subscription_button"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:padding="14dp"
                android:background="@drawable/launcher_button_primary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_trial_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="#FFE0B2"
                android:textSize="12sp"
                android:visibility="gone" />

            <com.google.android.gms.ads.AdView
                xmlns:ads="http://schemas.android.com/apk/res-auto"
                android:id="@+id/ad_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                ads:adSize="BANNER"
                ads:adUnitId="@string/admob_banner_ad_unit_id" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
